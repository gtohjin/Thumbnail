# ========================
# API Keys
# ========================
OPENAI_API_KEY=your_openai_api_key_here
STABILITY_API_KEY=your_stability_api_key_here

# ========================
# Provider 설정
# ========================
# 사용할 provider: openai | stability
DEFAULT_PROVIDER=openai

# ========================
# 경로 설정
# ========================
OUTPUT_DIR=outputs
PRESETS_DIR=presets

# ========================
# 이미지 설정
# ========================
# 정사각형 캔버스 크기 (스마트스토어 권장: 1000 이상)
CANVAS_SIZE=1024

# ========================
# 생성 설정
# ========================
MAX_WORKERS=4
MAX_RETRIES=3
LOG_LEVEL=INFO
